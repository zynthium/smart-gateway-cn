# Sing-box Manager Environment Variables
# 该文件默认保存在 /etc/sing-box/.env
# 注意：配置修改后需重新运行脚本执行 update 或重载才能生效

# 1. 订阅链接字符串 (必须)
# 支持配置多个订阅链接，请使用逗号 `,` 分隔。
SUB_URLS_STR="https://sub.example.com/link1,https://sub.example.com/link2"

# 2. Web Dashboard API 端口 (可选，默认 9090)
# 此端口用于外部控制器和 Dashboard 访问。
API_PORT="9090"

# 3. Web Dashboard 访问密钥 (可选，默认 singbox_admin)
# 请务必设置复杂的密码以确保安全。
API_SECRET="my_secure_password"

# 4. 地区优先级及正则匹配配置 (可选)
# 格式为 "分组名:正则匹配1|正则匹配2,分组名:正则匹配1"
# 节点组将按此处从左到右的顺序进行优先级降级排列。
PRIORITY_REGIONS_STR="SG:新加坡|SG|Singapore,US:美国|US|United States,JP:日本|JP|Japan,HK:香港|HK|Hong Kong"